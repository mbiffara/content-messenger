generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  name         String?
  passwordHash String
  role         String          @default("admin") // "super_admin" | "account_admin" | "admin"
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  memberships  AccountMember[]
}

model Account {
  id                String          @id @default(cuid())
  name              String
  slug              String          @unique
  whatsappSessionId String          @unique @default(cuid())
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  members           AccountMember[]
  subscribers       Subscriber[]
  lessons           Lesson[]
  broadcasts        Broadcast[]
  deliveries        Delivery[]
  settings          Setting[]
}

model AccountMember {
  id        String   @id @default(cuid())
  userId    String
  accountId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  account   Account  @relation(fields: [accountId], references: [id])

  @@unique([userId, accountId])
}

model Subscriber {
  id              String     @id @default(cuid())
  accountId       String
  email           String
  name            String?
  phone           String?
  whatsappJid     String?
  ghostId         String?
  note            String?
  active          Boolean    @default(true)
  currentPosition Int        @default(0)
  startedAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  account         Account    @relation(fields: [accountId], references: [id])
  deliveries      Delivery[]

  @@unique([accountId, email])
  @@unique([accountId, whatsappJid])
}

model Lesson {
  id            String     @id @default(cuid())
  accountId     String
  title         String
  audioUrl      String?
  audioFileName String?
  body          String?
  imageUrl      String?
  position      Int
  status        String     @default("draft") // "draft" | "published"
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  account       Account    @relation(fields: [accountId], references: [id])
  deliveries    Delivery[]
}

model Broadcast {
  id            String     @id @default(cuid())
  accountId     String
  title         String
  body          String?
  imageUrl      String?
  audioUrl      String?
  audioFileName String?
  status        String     @default("draft") // "draft" | "scheduled" | "sent"
  scheduledAt   DateTime?
  sentAt        DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  account       Account    @relation(fields: [accountId], references: [id])
  deliveries    Delivery[]
}

model Delivery {
  id            String     @id @default(cuid())
  accountId     String
  subscriberId  String
  lessonId      String?
  broadcastId   String?
  status        String     @default("pending") // "pending" | "sent" | "delivered" | "failed"
  whatsappMsgId String?
  sentAt        DateTime?
  createdAt     DateTime   @default(now())
  account       Account    @relation(fields: [accountId], references: [id])
  subscriber    Subscriber @relation(fields: [subscriberId], references: [id])
  lesson        Lesson?    @relation(fields: [lessonId], references: [id])
  broadcast     Broadcast? @relation(fields: [broadcastId], references: [id])

  @@unique([lessonId, subscriberId])
  @@unique([broadcastId, subscriberId])
}

model Setting {
  id        String   @id @default(cuid())
  accountId String
  key       String
  value     String
  updatedAt DateTime @updatedAt
  account   Account  @relation(fields: [accountId], references: [id])

  @@unique([accountId, key])
}
